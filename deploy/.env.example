# Copy to deploy/.env on Oracle VM (never commit .env)

# Neon PostgreSQL — lấy từ Neon Dashboard → Connection string
ConnectionStrings__DefaultConnection=Host=ep-xxxx.ap-southeast-1.aws.neon.tech;Port=5432;Database=neondb;Username=neondb_owner;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# GitHub Pages URL (không có dấu / cuối)
Cors__Origins__0=https://vuaconga1.github.io

# Tuỳ chọn — game phát âm
AzureSpeech__Key=
AzureSpeech__Region=southeastasia
